# ── Compiled output ───────────────────────────────────────────────────────────
dist/
tmp/
out-tsc/
*.tsbuildinfo

# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/

# ── Environment variables (NEVER commit these) ────────────────────────────────
.env
.env.*
!.env.example

# ── Large / unnecessary assets ────────────────────────────────────────────────
attached_assets/

# ── Replit-specific files ─────────────────────────────────────────────────────
.replit
.replitignore
.gitattributes
.cache/
.local/
.agents/
.config/
.npmrc
replit.md
artifacts/mockup-sandbox/

# ── IDEs ──────────────────────────────────────────────────────────────────────
.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# ── VS Code (keep useful settings, ignore personal/machine-specific) ──────────
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# ── System files ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
npm-debug.log
yarn-error.log
testem.log

# ── Misc ──────────────────────────────────────────────────────────────────────
.sass-cache/
coverage/
/typings
.expo/
.expo-shared/